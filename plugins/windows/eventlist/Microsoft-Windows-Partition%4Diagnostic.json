{
  "1006":{
    "description": "Device inserted or removed from the system",
    "provider": "Microsoft-Windows-Partition",
    "category": ["driver"],
    "type": ["connection"],
    "path": {
      "EventData":{
        "Name": ["Manufacturer", "Capacity", "Model", "DiskId", "ParentId", "RegistryId", "PartitionTableBytes", "SerialNumber"],
        "transform": {"ParentId": "data.device_id", "DiskId": "data.device_guid", "Manufacturer": "data.device_vendor", "Model": "data.device_model", "SerialNumber": "data.device_serial_number"}
      }
    }
  }
}
